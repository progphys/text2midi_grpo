{
  "data": {
    "name": "teacher_encoded_full",
    "json_path": "data/HTCanon/encoded_full/teacher_encoded.json",
    "metadata_dir": "metadata",
    "split": {
      "train": "train",
      "val": "val"
    },
    "structured_only": false
  },
  "dataloader": {
    "name": "observer_pairs_song_theory",
    "batch_size": 128,
    "num_workers": 0,
    "shuffle": true,
    "pin_memory": false,
    "drop_last": false,
    "corruption_backend": "song_theory",
    "corruption_modes": [
      "strongbeat_nonchord_note",
      "borrowed_melody_conflict",
      "note_onset_shift",
      "strong_weak_beat_flip"
    ],
    "theory_aware": {
      "strongbeat_min_duration": 1.0,
      "strongbeat_only": true,
      "balance_mode_usage": false,
      "deterministic_per_sample": true,
      "deterministic_seed": 123
    },
    "pairs_per_song": 1,
    "pair_mode_strategy": "first_applicable",
    "max_pairs_per_split_per_mode": null,
    "max_pairs_per_mode_by_split": {}
  },
  "observer_pipeline": {
    "output_root": "outputs/fixed_corruption_pairs_v1",
    "build_pairs": false,
    "build_targets": false,
    "build_graph_cache": true,
    "train": true,
    "overwrite": false,
    "skip_render_failures": true,
    "skip_graph_build_failures": true,
    "encoded_output_dir": "pairs/encoded",
    "midi_output_dir": "pairs/midi",
    "manifest_output_dir": "pairs/manifests",
    "targets_output_dir": "targets",
    "cache_output_dir": "cache"
  },
  "observer_model": {
    "name": "observer_gnn_default",
    "hidden_dim": 128,
    "num_layers": 3,
    "dropout": 0.1
  },
  "observer_training": {
    "name": "observer_training_default",
    "epochs": 60,
    "seed": 42,
    "device": "cuda",
    "teacher_checkpoint": "supplementary/critic_assets/observer_fixed_pairs/teacher/best_rank_acc.pt",
    "teacher_config": "supplementary/critic_assets/observer_fixed_pairs/teacher/config.yaml",
    "chord_weights_yaml": "src/core/critics/observer/assets/learned_weights.yaml",
    "chord_instrument_name": "chords",
    "use_fallback_44": true,
    "resume": false
  },
  "optimizer": {
    "name": "adamw",
    "lr": 0.001,
    "weight_decay": 0.0001,
    "betas": [
      0.9,
      0.999
    ]
  },
  "scheduler": {
    "name": "none"
  },
  "losses": {
    "lambda_reg": 1.0,
    "lambda_rank": 0.5,
    "min_teacher_gap_for_rank": 0.25,
    "use_pair_rank": true,
    "use_batch_rank": true,
    "rank_intra_weight": 1.0,
    "rank_inter_weight": 1.0
  },
  "project": {
    "name": "Fine-tune-text2midi-llm-with-gnn-theory-critic",
    "task": "observer_pair_distill"
  },
  "run_name": "observer_fixed_corruption_pairs_v1_cache_train"
}
